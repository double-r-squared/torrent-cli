# Copy to `.env` for running docker-compose.yml by hand. Gitignored — holds
# your VPN secret. (`torrent-cli up` generates its own .env from your settings,
# so you only need this for manual `docker compose` use.)
#
# ProtonVPN WireGuard values come from account.protonvpn.com ->
# Downloads -> WireGuard configuration. Generate a config and copy the
# PrivateKey and Address out of the .conf file.

VPN_SERVICE_PROVIDER=protonvpn
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key
WIREGUARD_ADDRESSES=10.2.0.2/32
# Optional: pin exit country/countries (comma-separated). Blank = fastest.
SERVER_COUNTRIES=Switzerland

# Container user/group (match your host user so mounted files are owned right).
PUID=1000
PGID=1000
TZ=Etc/UTC
